    },
    "episode_id": {
      "title": "Episode Id",
      "type": "string"
    },
    "timepoint_id": {
      "title": "Timepoint Id",
      "type": "string"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "mode": {
