    },
    "graph_version": {
      "title": "Graph Version",
      "type": "string"
    },
    "node_library_version": {
      "title": "Node Library Version",
      "type": "string"
    },
    "available_fact_ids": {
      "items": {
        "type": "string"
      },
      "title": "Available Fact Ids",
