{
  "$defs": {
    "EvidenceCandidateInput": {
      "additionalProperties": false,
      "properties": {
        "input_id_template": {
          "title": "Input Id Template",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "input_category": {
          "title": "Input Category",
          "type": "string"
        },
        "burden": {
          "title": "Burden",
          "type": "string"
        },
        "time_to_obtain_hours": {
          "minimum": 0,
          "title": "Time To Obtain Hours",
          "type": "number"
        },
        "result_distribution": {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Result Distribution",
          "type": "array"
        },
        "expected_posture_shift": {
          "maximum": 1,
          "minimum": 0,
          "title": "Expected Posture Shift",
          "type": "number"
        },
        "preventability_leverage": {
          "maximum": 1,
          "minimum": 0,
          "title": "Preventability Leverage",
          "type": "number"
        }
      },
      "required": [
        "input_id_template",
        "description",
        "input_category",
        "burden",
        "time_to_obtain_hours",
        "expected_posture_shift",
        "preventability_leverage"
      ],
      "title": "EvidenceCandidateInput",
      "type": "object"
    },
    "EvidenceFlowOutputs": {
      "additionalProperties": false,
      "properties": {
        "required_variables": {
          "items": {
            "type": "string"
          },
          "title": "Required Variables",
          "type": "array"
        },
        "missing_variables": {
          "items": {
            "type": "string"
          },
          "title": "Missing Variables",
          "type": "array"
        },
        "candidate_inputs": {
          "items": {
            "$ref": "#/$defs/EvidenceCandidateInput"
          },
          "title": "Candidate Inputs",
          "type": "array"
        },
        "evidence_support_strength": {
          "default": 0,
          "maximum": 1,
          "minimum": 0,
          "title": "Evidence Support Strength",
          "type": "number"
        },
        "evidence_conflict_strength": {
          "default": 0,
          "maximum": 1,
          "minimum": 0,
          "title": "Evidence Conflict Strength",
          "type": "number"
        },
        "uncertainty_notes": {
          "items": {
            "type": "string"
          },
          "title": "Uncertainty Notes",
          "type": "array"
        }
      },
      "title": "EvidenceFlowOutputs",
      "type": "object"
    },
    "EvidenceFlowTemplate": {
      "additionalProperties": false,
      "properties": {
        "flow_id_template": {
          "title": "Flow Id Template",
          "type": "string"
        },
        "flow_type": {
          "title": "Flow Type",
          "type": "string"
        },
        "timepoint_id": {
          "$ref": "#/$defs/RequiredTimepoint"
        },
        "outputs": {
          "$ref": "#/$defs/EvidenceFlowOutputs"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "sources": {
          "items": {
            "type": "string"
          },
          "title": "Sources",
          "type": "array"
        },
        "evidence_version": {
          "title": "Evidence Version",
          "type": "string"
        }
      },
      "required": [
        "flow_id_template",
        "flow_type",
        "timepoint_id",
        "outputs",
        "confidence",
        "evidence_version"
      ],
      "title": "EvidenceFlowTemplate",
      "type": "object"
    },
    "RequiredTimepoint": {
      "enum": [
        "T0_triage",
        "T1_initial_workup",
        "T2_post_treatment_reassessment",
        "T3_disposition_decision",
        "T4_follow_up_or_outcome"
      ],
      "title": "RequiredTimepoint",
      "type": "string"
    },
    "RoleAssessmentTemplate": {
      "additionalProperties": false,
      "properties": {
        "assessment_id_template": {
          "title": "Assessment Id Template",
          "type": "string"
        },
        "role_name": {
          "title": "Role Name",
          "type": "string"
        },
        "timepoint_id": {
          "$ref": "#/$defs/RequiredTimepoint"
        },
        "assessment_scope": {
          "title": "Assessment Scope",
          "type": "string"
        },
        "findings": {
          "items": {
            "$ref": "#/$defs/StaticFinding"
          },
          "minItems": 1,
          "title": "Findings",
          "type": "array"
        },
        "overall_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Overall Confidence",
          "type": "number"
        },
        "missing_information_identified": {
          "items": {
            "type": "string"
          },
          "title": "Missing Information Identified",
          "type": "array"
        },
        "uncertainty_notes": {
          "items": {
            "type": "string"
          },
          "title": "Uncertainty Notes",
          "type": "array"
        },
        "sources_used": {
          "items": {
            "type": "string"
          },
          "title": "Sources Used",
          "type": "array"
        }
      },
      "required": [
        "assessment_id_template",
        "role_name",
        "timepoint_id",
        "assessment_scope",
        "findings",
        "overall_confidence"
      ],
      "title": "RoleAssessmentTemplate",
      "type": "object"
    },
    "StaticFinding": {
      "additionalProperties": false,
      "properties": {
        "finding_id_template": {
          "title": "Finding Id Template",
          "type": "string"
        },
        "finding_type": {
          "title": "Finding Type",
          "type": "string"
        },
        "structured_value": {
          "additionalProperties": true,
          "title": "Structured Value",
          "type": "object"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "rationale_short": {
          "title": "Rationale Short",
          "type": "string"
        },
        "source_refs": {
          "items": {
            "type": "string"
          },
          "title": "Source Refs",
          "type": "array"
        },
        "node_targets": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Node Targets",
          "type": "array"
        },
        "evidence_tier": {
          "title": "Evidence Tier",
          "type": "string"
        }
      },
      "required": [
        "finding_id_template",
        "finding_type",
        "confidence",
        "rationale_short",
        "node_targets",
        "evidence_tier"
      ],
      "title": "StaticFinding",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "bundle_id": {
      "title": "Bundle Id",
      "type": "string"
    },
    "version": {
      "title": "Version",
      "type": "string"
    },
    "applies_to": {
      "title": "Applies To",
      "type": "string"
    },
    "role_assessment_templates": {
      "items": {
        "$ref": "#/$defs/RoleAssessmentTemplate"
      },
      "title": "Role Assessment Templates",
      "type": "array"
    },
    "evidenceflow_templates": {
      "items": {
        "$ref": "#/$defs/EvidenceFlowTemplate"
      },
      "title": "Evidenceflow Templates",
      "type": "array"
    }
  },
  "required": [
    "bundle_id",
    "version",
    "applies_to"
  ],
  "title": "StaticInputBundle",
  "type": "object"
}
