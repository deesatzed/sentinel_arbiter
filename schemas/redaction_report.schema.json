{
  "$defs": {
    "RedactionFindingRecord": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "start": {
          "minimum": 0,
          "title": "Start",
          "type": "integer"
        },
        "end": {
          "minimum": 0,
          "title": "End",
          "type": "integer"
        },
        "text_hash": {
          "title": "Text Hash",
          "type": "string"
        }
      },
      "required": [
        "label",
        "start",
        "end",
        "text_hash"
      ],
      "title": "RedactionFindingRecord",
      "type": "object"
    },
    "ResidualFindingRecord": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "pattern": {
          "title": "Pattern",
          "type": "string"
        }
      },
      "required": [
        "label",
        "pattern"
      ],
      "title": "ResidualFindingRecord",
      "type": "object"
    }
